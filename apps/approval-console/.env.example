
# Optional. If omitted, the Console runs in export-only mode.
# Do not commit real credentials.
DATABASE_URL=postgres://APPROVAL_CONSOLE_USER:APPROVAL_CONSOLE_PASSWORD@postgres:5432/APPROVAL_CONSOLE_DB

# Next.js runtime.
NODE_ENV=production

# Article generation LLM.
# OpenAI-compatible chat completions endpoint.
# Do not commit real API keys.
ARTICLE_LLM_PROVIDER=openai_compatible
ARTICLE_LLM_BASE_URL=https://api.openai.com/v1
ARTICLE_LLM_API_KEY=
ARTICLE_LLM_MODEL=
ARTICLE_LLM_TIMEOUT_MS=120000
